From fd5bb678ef3b73da8739cd479205008772dd7cfb Mon Sep 17 00:00:00 2001
From: Akbar Hamaminatu <gasiyu@proton.me>
Date: Wed, 1 Apr 2026 13:00:51 +0700
Subject: [PATCH] [PATCH 1/3] Fix Makefile for packaging

---
 Makefile | 6 +++---
 1 file changed, 3 insertions(+), 3 deletions(-)

diff --git a/Makefile b/Makefile
index 3bad5b62..28338b1c 100644
--- a/Makefile
+++ b/Makefile
@@ -25,7 +25,7 @@ GOLANGCI_LINT_VERSION ?= v2.11.1
 
 UI_SRC_FILES := $(shell find ui -type f -not -path "ui/build/*" -not -path "ui/node_modules/*")
 
-setup: check_env download-deps install-golangci-lint setup-git ##@1_Run_First Install dependencies and prepare development environment
+setup: ##@1_Run_First Install dependencies and prepare development environment
 	@echo Downloading Node dependencies...
 	@(cd ./ui && npm ci)
 .PHONY: setup
@@ -144,7 +144,7 @@ setup-git: ##@Development Setup Git hooks (pre-commit and pre-push)
 	@(cd .git/hooks && ln -sf ../../git/* .)
 .PHONY: setup-git
 
-build: check_go_env buildjs ##@Build Build the project
+build: buildjs ##@Build Build the project
 	go build -ldflags="-X github.com/navidrome/navidrome/consts.gitSha=$(GIT_SHA) -X github.com/navidrome/navidrome/consts.gitTag=$(GIT_TAG)" -tags=$(GO_BUILD_TAGS)
 .PHONY: build
 
@@ -155,7 +155,7 @@ debug-build: check_go_env buildjs ##@Build Build the project (with remote debug
 	go build -gcflags="all=-N -l" -ldflags="-X github.com/navidrome/navidrome/consts.gitSha=$(GIT_SHA) -X github.com/navidrome/navidrome/consts.gitTag=$(GIT_TAG)" -tags=$(GO_BUILD_TAGS)
 .PHONY: debug-build
 
-buildjs: check_node_env ui/build/index.html ##@Build Build only frontend
+buildjs: ui/build/index.html ##@Build Build only frontend
 .PHONY: buildjs
 
 docker-buildjs: ##@Build Build only frontend using Docker
-- 
